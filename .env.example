# Скопируйте в .env (он не коммитится) и задайте значения.
# На Railway/хостинге эти переменные задаются в настройках проекта.

# Общий пароль для доступа к редактированию и данным. Пусто = доступ открыт.
APP_PASSWORD=

# Куда писать файлы данных (правки/комментарии). На Railway — путь примонтированного тома, напр. /data
# DATA_DIR=
